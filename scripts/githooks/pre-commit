#!/usr/bin/env bash
# ============================================================
# pre-commit —— 让"代码审判文档"自动发生
# 任何提交前，角色包必须仍然符合 role-package.schema.md。
# 版本化于 repo 内，经 `git config core.hooksPath scripts/githooks` 生效。
# ============================================================
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

if ! python3 "$repo_root/scripts/validate_roles.py"; then
  echo ""
  echo "pre-commit blocked: role packages violate role-package.schema.md" >&2
  echo "fix the role files above, or run: python3 scripts/validate_roles.py" >&2
  exit 1
fi

if ! python3 "$repo_root/scripts/validate_mounted_agents.py"; then
  echo ""
  echo "pre-commit blocked: mounted agents violate assembled agent contract" >&2
  echo "fix the mounted agent files above, or run: python3 scripts/validate_mounted_agents.py" >&2
  exit 1
fi
